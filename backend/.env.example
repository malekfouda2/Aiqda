NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://localhost:27017/aiqda
JWT_SECRET=your-secret-key
FRONTEND_URL=http://localhost:5000
TRUST_PROXY=1
LEGACY_LESSON_PUBLISH_BACKFILL_CUTOFF=2026-04-05T00:00:00.000Z
VIMEO_ACCESS_TOKEN=
AUTO_SEED_DEMO_DATA=true
AUTO_SEED_CONSULTATIONS=true
ALLOW_PRODUCTION_AUTO_SEED=false
AUTH_REGISTER_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_SOCIAL_RATE_LIMIT_MAX=20
INVITE_ACCEPT_RATE_LIMIT_MAX=10
CONTACT_SUBMISSION_RATE_LIMIT_MAX=5
INSTRUCTOR_APPLICATION_RATE_LIMIT_MAX=5
STUDIO_APPLICATION_RATE_LIMIT_MAX=5

# SMTP email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=Aiqda <notifications@example.com>
CONTACT_NOTIFICATION_TO=support@example.com

# Social login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=

# Studio approval scheduling
STUDIO_APPLICATION_MEETING_URL=https://scheduler.example.com/aiqda/studio-intro
